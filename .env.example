GEMINI_API_KEY=replace_with_your_gemini_api_key

# Optional. Default model when the frontend doesn't send one.
# Must be one of:
#   gemini-3-flash-preview, gemini-3.5-flash, gemini-3.1-flash-lite,
#   gemini-2.5-flash, gemini-2.0-flash
# If unset or not in the allowlist, the server falls back to gemini-3-flash-preview
# (and logs a warning if the value was invalid).
GEMINI_MODEL=gemini-3-flash-preview

# Optional. If set to "true", the server will fall back to mock feedback
# when a Gemini call fails (e.g. HTTP 429 quota, network error, suspended key).
# Recommended: true for a smooth local dev experience.
USE_MOCK_ON_GEMINI_ERROR=true
